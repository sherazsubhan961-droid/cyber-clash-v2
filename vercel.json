{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/register",
            "destination": "/api/register.js"
        },
        {
            "source": "/api/approve",
            "destination": "/api/approve.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
